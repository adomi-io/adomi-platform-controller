POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo

ODOO_DB_HOST=app_odoo_db
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=odoo
ODOO_DB_PORT=5432

# The Odoo database the management addon is installed into (used by the setup hook).
ODOO_DB_NAME=odoo

# Namespace the platform CRs (Client/Workspace/Application/...) live in.
# Read by the addon via the adomi_platform.namespace system parameter; the hook can
# also seed it. Defaults to adomi-system.
# PLATFORM_NAMESPACE=adomi-system
