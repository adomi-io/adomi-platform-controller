<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- The Home dashboard (OWL client action). The menu lives in menus.xml at the
         top sequence so the root menu auto-opens it as the landing page. -->
    <record id="action_adomi_dashboard" model="ir.actions.client">
        <field name="name">Home</field>
        <field name="tag">adomi_dashboard</field>
    </record>

    <!-- Discover + import every platform resource from the cluster into Odoo
         (new CRs become records; known ones get a status refresh). Also runs on
         the hourly fallback cron and on every controller status push. -->
    <record id="action_adomi_sync_cluster" model="ir.actions.server">
        <field name="name">Sync from cluster</field>
        <field name="model_id" ref="model_adomi_application"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_all()
action = {"type": "ir.actions.client", "tag": "reload"}</field>
    </record>
</odoo>
