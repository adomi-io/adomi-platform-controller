<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_adomi_git_repository_list" model="ir.ui.view">
        <field name="name">adomi.git.repository.list</field>
        <field name="model">adomi.git.repository</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="client_id"/>
                <field name="url" widget="url"/>
                <field name="default_branch"/>
                <field name="preview_enabled"/>
                <field name="k8s_state" widget="badge"
                       decoration-success="k8s_state == 'ready'"
                       decoration-danger="k8s_state == 'not_ready'"
                       decoration-warning="k8s_state == 'pending'"/>
            </list>
        </field>
    </record>

    <record id="view_adomi_git_repository_form" model="ir.ui.view">
        <field name="name">adomi.git.repository.form</field>
        <field name="model">adomi.git.repository</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_k8s_sync" type="object" string="Sync from cluster" class="btn-secondary"/>
                    <field name="k8s_state" widget="statusbar" statusbar_visible="pending,ready"/>
                </header>
                <sheet>
                    <field name="id" widget="adomi_bus_listener" nolabel="1"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="k8s_name"/>
                            <field name="client_id"/>
                            <field name="url"/>
                            <field name="default_branch"/>
                            <field name="credentials_secret"/>
                        </group>
                        <group string="PR previews">
                            <field name="preview_enabled"/>
                            <field name="preview_client_id" invisible="not preview_enabled"/>
                            <field name="preview_application_type" invisible="not preview_enabled"/>
                            <field name="k8s_message" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_adomi_git_repository" model="ir.actions.act_window">
        <field name="name">Git Repositories</field>
        <field name="res_model">adomi.git.repository</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
