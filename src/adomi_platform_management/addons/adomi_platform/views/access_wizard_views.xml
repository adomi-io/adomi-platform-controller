<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_adomi_app_access_wizard_form" model="ir.ui.view">
        <field name="name">adomi.app.access.wizard.form</field>
        <field name="model">adomi.app.access.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="application_id" readonly="1"/>
                        <field name="user_id" options="{'no_create': True}"/>
                    </group>
                    <div class="text-muted">
                        Granting the first user restricts the app to the people listed —
                        everyone else gets an Authentik denial. Removing the last user
                        opens it up to every signed-in account again.
                    </div>
                </sheet>
                <footer>
                    <button string="Grant access" name="action_grant" type="object"
                            class="btn-primary"/>
                    <button string="Discard" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
