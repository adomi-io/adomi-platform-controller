<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Lowest root sequence (Discuss ships at 5) so Adomi Platform is the first
         app and the post-login landing page. -->
    <menuitem id="menu_adomi_root" name="Adomi Platform"
              groups="base.group_user" sequence="1"/>

    <!-- Home dashboard is the landing page: the root menu auto-opens its first
         leaf, so this must have the lowest sequence. -->
    <menuitem id="menu_adomi_home" name="Home"
              parent="menu_adomi_root" action="action_adomi_dashboard" sequence="1"/>

    <!-- Customers (kanban): the platform is organised around the end customer,
         with apps deployed under each. -->
    <menuitem id="menu_adomi_clients" name="Customers"
              parent="menu_adomi_root" action="action_adomi_client" sequence="10"/>
    <menuitem id="menu_adomi_deploy" name="Deploy Application"
              parent="menu_adomi_root" action="action_adomi_deploy_wizard" sequence="15"/>
    <menuitem id="menu_adomi_applications" name="Applications"
              parent="menu_adomi_root" action="action_adomi_application" sequence="20"/>
    <menuitem id="menu_adomi_environments" name="Environments"
              parent="menu_adomi_root" action="action_adomi_environment" sequence="30"/>
    <menuitem id="menu_adomi_snapshots" name="Snapshots"
              parent="menu_adomi_root" action="action_adomi_snapshot" sequence="40"/>

    <!-- Infrastructure: the shared capability resources customers' apps attach to. -->
    <menuitem id="menu_adomi_infrastructure" name="Infrastructure"
              parent="menu_adomi_root" sequence="45"/>
    <menuitem id="menu_adomi_database_servers" name="Database Servers"
              parent="menu_adomi_infrastructure" action="action_adomi_database_server" sequence="10"/>
    <menuitem id="menu_adomi_domains" name="Domains"
              parent="menu_adomi_infrastructure" action="action_adomi_domain" sequence="20"/>

    <!-- Sources -->
    <menuitem id="menu_adomi_sources" name="Sources" parent="menu_adomi_root" sequence="50"/>
    <menuitem id="menu_adomi_git_repositories" name="Git Repositories"
              parent="menu_adomi_sources" action="action_adomi_git_repository" sequence="10"/>

    <!-- Catalog -->
    <menuitem id="menu_adomi_catalog" name="Catalog" parent="menu_adomi_root" sequence="60"/>
    <menuitem id="menu_adomi_application_types" name="Application Types"
              parent="menu_adomi_catalog" action="action_adomi_application_type" sequence="10"/>
    <menuitem id="menu_adomi_import_types" name="Import from cluster"
              parent="menu_adomi_catalog" action="action_import_application_types" sequence="20"/>

    <!-- Configuration -->
    <menuitem id="menu_adomi_config" name="Configuration" parent="menu_adomi_root" sequence="90"/>
    <menuitem id="menu_adomi_github_accounts" name="GitHub"
              parent="menu_adomi_config" action="action_adomi_github_app" sequence="5"/>
    <menuitem id="menu_adomi_sync_cluster" name="Sync from cluster"
              parent="menu_adomi_config" action="action_adomi_sync_cluster" sequence="8"/>
    <menuitem id="menu_adomi_organizations" name="Organizations"
              parent="menu_adomi_config" action="action_adomi_organization" sequence="10"/>
</odoo>
