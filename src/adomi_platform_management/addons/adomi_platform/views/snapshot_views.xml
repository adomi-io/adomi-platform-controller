<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_adomi_snapshot_list" model="ir.ui.view">
        <field name="name">adomi.snapshot.list</field>
        <field name="model">adomi.snapshot</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="application_id"/>
                <field name="phase"/>
                <field name="location"/>
                <field name="k8s_state" widget="badge"
                       decoration-success="k8s_state == 'ready'"
                       decoration-danger="k8s_state == 'not_ready'"
                       decoration-warning="k8s_state == 'pending'"/>
            </list>
        </field>
    </record>

    <record id="view_adomi_snapshot_form" model="ir.ui.view">
        <field name="name">adomi.snapshot.form</field>
        <field name="model">adomi.snapshot</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_k8s_sync" type="object" string="Sync from cluster" class="btn-secondary"/>
                    <field name="k8s_state" widget="statusbar" statusbar_visible="pending,ready"/>
                </header>
                <sheet>
                    <field name="id" widget="adomi_bus_listener" nolabel="1"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="k8s_name"/>
                            <field name="application_id"/>
                        </group>
                        <group string="Status">
                            <field name="phase" readonly="1"/>
                            <field name="location" readonly="1"/>
                            <field name="k8s_message" readonly="1"/>
                            <field name="k8s_last_sync" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_adomi_snapshot" model="ir.actions.act_window">
        <field name="name">Snapshots</field>
        <field name="res_model">adomi.snapshot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
