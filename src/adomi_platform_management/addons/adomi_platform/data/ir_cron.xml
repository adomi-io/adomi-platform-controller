<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Fallback reconcile only. The platform controller pushes status changes to
         /adomi_platform/ingest in real time, so this cron exists just to catch
         anything missed while the portal was unavailable. Runs hourly. -->
    <record id="cron_sync_platform" model="ir.cron">
        <field name="name">Adomi: reconcile platform status (fallback)</field>
        <field name="model_id" ref="model_adomi_application"/>
        <field name="state">code</field>
        <field name="code">model.cron_sync_all()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
