<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="adomi_platform.Dashboard">
        <div class="o_adomi_dashboard p-4">
            <div class="o_adomi_hero mb-4 d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="mb-1">Adomi Platform</h1>
                    <p class="text-muted mb-0">Your control center for customers, applications and infrastructure.</p>
                </div>
                <button class="btn btn-outline-secondary" t-on-click="() => this.syncCluster()" t-att-disabled="state.syncing">
                    <i t-att-class="'fa me-1 ' + (state.syncing ? 'fa-circle-o-notch fa-spin' : 'fa-refresh')"/>
                    <t t-esc="state.syncing ? 'Syncing…' : 'Sync from cluster'"/>
                </button>
            </div>

            <t t-if="state.loading">
                <div class="text-center text-muted py-5">
                    <i class="fa fa-circle-o-notch fa-spin fa-2x"/>
                </div>
            </t>
            <t t-else="">
                <!-- High-level stats -->
                <div class="row g-3 mb-4">
                    <div class="col-6 col-lg-3">
                        <div class="o_adomi_stat card h-100" t-on-click="() => this.open('adomi_platform.action_adomi_client')">
                            <div class="card-body">
                                <div class="o_adomi_stat_value"><t t-esc="state.stats.customers"/></div>
                                <div class="o_adomi_stat_label"><i class="fa fa-users me-1"/>Customers</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="o_adomi_stat card h-100" t-on-click="() => this.open('adomi_platform.action_adomi_application')">
                            <div class="card-body">
                                <div class="o_adomi_stat_value">
                                    <t t-esc="state.stats.appsReady"/><span class="text-muted">/<t t-esc="state.stats.appsTotal"/></span>
                                </div>
                                <div class="o_adomi_stat_label"><i class="fa fa-cubes me-1"/>Apps ready</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="o_adomi_stat card h-100" t-on-click="() => this.open('adomi_platform.action_adomi_database_server')">
                            <div class="card-body">
                                <div class="o_adomi_stat_value"><t t-esc="state.stats.dbServers"/></div>
                                <div class="o_adomi_stat_label"><i class="fa fa-database me-1"/>Database servers</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-lg-3">
                        <div class="o_adomi_stat card h-100" t-on-click="() => this.open('adomi_platform.action_adomi_environment')">
                            <div class="card-body">
                                <div class="o_adomi_stat_value"><t t-esc="state.stats.environments"/></div>
                                <div class="o_adomi_stat_label"><i class="fa fa-layer-group me-1"/>Environments</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Getting started (shown until every step is done) -->
                <t t-if="!state.allDone">
                    <div class="card o_adomi_getstarted mb-4">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <h4 class="mb-0">🚀 Getting started with Adomi</h4>
                                <span class="badge text-bg-primary"><t t-esc="completedCount"/> / <t t-esc="state.steps.length"/> done</span>
                            </div>
                            <p class="text-muted">A few steps to get your platform up and running.</p>
                            <div class="row g-3">
                                <t t-foreach="state.steps" t-as="step" t-key="step.key">
                                    <div class="col-12 col-lg-6">
                                        <div class="o_adomi_step d-flex align-items-start p-3 border rounded h-100" t-att-class="step.done ? 'o_done' : ''">
                                            <div class="o_adomi_step_icon me-3">
                                                <i t-att-class="'fa fa-2x ' + (step.done ? 'fa-check-circle text-success' : step.icon + ' text-primary')"/>
                                            </div>
                                            <div class="flex-grow-1">
                                                <div class="fw-bold">
                                                    <t t-esc="step.title"/>
                                                    <span t-if="step.done" class="badge text-bg-success ms-2">Done</span>
                                                </div>
                                                <div class="text-muted small mb-2"><t t-esc="step.desc"/></div>
                                                <button t-if="!step.done" class="btn btn-sm btn-primary" t-on-click="() => this.open(step.action)">
                                                    <t t-esc="step.cta"/>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="alert alert-success d-flex align-items-center mb-4">
                        <i class="fa fa-check-circle fa-2x me-3"/>
                        <div><strong>You're all set!</strong> Your platform is configured — jump into a customer or deploy a new app.</div>
                    </div>
                </t>

                <!-- Quick links -->
                <h5 class="mb-3">Quick links</h5>
                <div class="row g-3">
                    <t t-foreach="quickLinks" t-as="link" t-key="link.title">
                        <div class="col-12 col-md-6 col-lg-4">
                            <div class="card o_adomi_quicklink h-100" t-on-click="() => this.open(link.action)">
                                <div class="card-body d-flex align-items-center">
                                    <div t-att-class="'o_adomi_ql_icon me-3 text-bg-' + link.color">
                                        <i t-att-class="'fa fa-fw ' + link.icon"/>
                                    </div>
                                    <div>
                                        <div class="fw-bold"><t t-esc="link.title"/></div>
                                        <div class="text-muted small"><t t-esc="link.desc"/></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>
