<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="adomi_platform.K8sBusListener" owl="1">
        <div>
            <t t-if="state.hasRemoteUpdate">
                <div class="alert alert-info d-flex align-items-center justify-content-between" role="alert">
                    <div class="me-3">
                        The cluster reported a change to this record. Refresh to see the latest status.
                    </div>
                    <button type="button" class="btn btn-sm btn-primary" t-on-click="reloadRecord">
                        Refresh now
                    </button>
                </div>
            </t>
        </div>
    </t>
</templates>
