<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_adomi_deploy_wizard_form" model="ir.ui.view">
        <field name="name">adomi.deploy.wizard.form</field>
        <field name="model">adomi.deploy.wizard</field>
        <field name="arch" type="xml">
            <form string="Deploy Application">
                <sheet>
                    <div class="oe_title">
                        <label for="app_name" string="Deploy a new application"/>
                        <h1><field name="app_name" placeholder="e.g. ERP, Reporting, Mail…"/></h1>
                    </div>
                    <group>
                        <group string="Customer">
                            <field name="organization_id" options="{'no_create': True}"/>
                            <field name="client_id" string="Customer" placeholder="Existing customer"
                                   options="{'no_create': True}"/>
                            <field name="new_client_name" string="…or new customer" invisible="client_id"/>
                            <field name="new_client_partner_id" invisible="client_id"/>
                        </group>
                        <group string="Workspace">
                            <field name="workspace_id" placeholder="Existing workspace"
                                   options="{'no_create': True}"/>
                            <field name="new_workspace_name" invisible="workspace_id"/>
                            <field name="new_workspace_class" invisible="workspace_id"/>
                        </group>
                    </group>
                    <separator string="Choose an application"/>
                    <field name="type_id" widget="adomi_app_catalog" nolabel="1"/>
                    <notebook>
                        <page string="Advanced">
                            <group>
                                <field name="hostname"/>
                            </group>
                        </page>
                    </notebook>
                    <footer>
                        <button name="action_deploy" type="object" string="Deploy" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_adomi_deploy_wizard" model="ir.actions.act_window">
        <field name="name">Deploy Application</field>
        <field name="res_model">adomi.deploy.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
